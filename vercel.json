{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/analyze",
      "destination": "https://ai-product-development-engineer-intern.onrender.com/analyze"
    },
    {
      "source": "/health",
      "destination": "https://ai-product-development-engineer-intern.onrender.com/health"
    },
    {
      "source": "/research",
      "destination": "https://ai-product-development-engineer-intern.onrender.com/research"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
